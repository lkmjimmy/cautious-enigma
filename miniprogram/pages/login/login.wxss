/**
 * Apple-like：中性背景、清晰字阶、底部主操作、轻阴影与圆角
 */
.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fafafa 0%, #f5f5f7 32%, #f5f5f7 100%);
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  padding-bottom: env(safe-area-inset-bottom);
}

.login-content {
  min-height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 48rpx);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.login-hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 32rpx;
  padding-bottom: 48rpx;
  text-align: center;
}

.login-headline {
  margin-top: 0;
  font-size: 44rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
  line-height: 1.12;
}

.login-brand-name {
  display: block;
  margin-top: 28rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.login-tagline {
  margin-top: 12rpx;
  font-size: 48rpx;
  font-weight: 500;
  color: #6e6e73;
  letter-spacing: 2rpx;
  line-height: 1.45;
}

.login-sub {
  margin-top: 16rpx;
  margin-left: auto;
  margin-right: auto;
  max-width: 560rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #86868b;
  line-height: 1.5;
}

.login-actions {
  width: 100%;
  padding-bottom: 16rpx;
}

.login-btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
  padding: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.5rpx;
  background: #07c160;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.22),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.login-btn-primary[disabled] {
  opacity: 0.55;
  box-shadow: none;
}

.login-btn-secondary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 20rpx 0 0;
  padding: 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: #1677ff;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 14rpx;
  border: 1rpx solid rgba(22, 119, 255, 0.35);
  box-shadow: 0 6rpx 18rpx rgba(22, 119, 255, 0.08);
}

.login-btn-secondary[disabled] {
  opacity: 0.55;
  box-shadow: none;
}

.login-footnote {
  margin-top: 28rpx;
  padding: 0 8rpx;
  font-size: 22rpx;
  font-weight: 400;
  color: #aeaeb2;
  line-height: 1.55;
  text-align: center;
}
