.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
}

.hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.badge.on {
  color: #389e0d;
  background: #f6ffed;
}

.badge.off {
  color: #64748b;
  background: #f1f5f9;
}

.line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.line .k {
  display: inline-block;
  min-width: 3.5em;
  color: #9ca3af;
  font-size: 24rpx;
}

.ad-block {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f1f5f9;
}

.ad-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 8rpx;
}

.ad-line {
  display: block;
  font-size: 24rpx;
  color: #111827;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.none-ad {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.tip {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.contract-preview {
  width: 100%;
  display: block;
  border-radius: 12rpx;
  border: 1rpx solid #e9eef5;
  margin-bottom: 16rpx;
}

.contract-empty {
  padding: 32rpx;
  margin-bottom: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 1rpx dashed #d1d5db;
}

.btn-upload {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: #1677ff;
  border-radius: 12rpx;
}

.btn-upload::after {
  border: none;
}

.clear-row {
  margin-top: 12rpx;
  text-align: center;
}

.clear-link {
  font-size: 22rpx;
  color: #9ca3af;
  text-decoration: underline;
}
