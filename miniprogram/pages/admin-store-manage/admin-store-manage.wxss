.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 20rpx;
}

.section--mgr {
  margin-top: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.type-table {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  overflow: hidden;
}

.type-head,
.type-row {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
}

.type-head {
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 23rpx;
  color: #6b7280;
}

.type-row {
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 25rpx;
  color: #111827;
}

.type-row:last-child {
  border-bottom: 0;
}

.col-type {
  flex: 1.6;
}

.col-num {
  flex: 1;
  text-align: center;
}

.num-success { color: #389e0d; }
.num-danger { color: #cf1322; }
.num-warning { color: #d48806; }
.num-expired { color: #991b1b; }

.mgr-store-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
}

.mgr-store-picker-label {
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.mgr-store-picker-inner {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}

.mgr-store-picker-value {
  font-size: 38rpx;
  font-weight: 600;
  color: #111827;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

.mgr-store-picker-arrow {
  font-size: 26rpx;
  color: #94a3b8;
}

.mgr-tip {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.mgr-owner-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 16rpx;
  padding: 16rpx 18rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.mgr-owner-bar--empty {
  color: #94a3b8;
  font-size: 24rpx;
}

.mgr-owner-label {
  color: #94a3b8;
  font-size: 22rpx;
}

.mgr-owner-name {
  color: #374151;
  font-weight: 600;
}

.mgr-owner-phone {
  color: #6b7280;
  font-size: 24rpx;
}

.mgr-slot-stats {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mgr-slot-stat {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e9eef5;
  padding: 16rpx 8rpx;
  text-align: center;
}

.mgr-slot-stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.mgr-slot-stat-val.tone-success { color: #16a34a; }
.mgr-slot-stat-val.tone-danger { color: #dc2626; }
.mgr-slot-stat-val.tone-warning { color: #d97706; }

.mgr-slot-stat-lb {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #64748b;
}

.mgr-type-block {
  margin-bottom: 24rpx;
}

.mgr-type-block-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.mgr-type-block-desc {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.mgr-type-table .type-head,
.mgr-type-table .type-row {
  padding: 14rpx 10rpx;
}

.mgr-type-table .type-head { font-size: 22rpx; }
.mgr-type-table .type-row { font-size: 24rpx; }
.mgr-type-table .col-type { flex: 1.15; min-width: 0; }
.mgr-type-table .col-num { flex: 0.85; min-width: 0; font-size: 22rpx; padding: 0 2rpx; }

.mgr-slot-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.mgr-slot-section-desc {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.mgr-slot-card {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  padding: 0;
  margin-bottom: 14rpx;
  overflow: hidden;
}

.mgr-slot-head {
  padding: 18rpx 18rpx 14rpx;
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
}

.mgr-slot-thumb-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #eef2f7;
}

.mgr-slot-thumb {
  width: 100%;
  height: 200rpx;
  display: block;
  background: #eef2f7;
}

.mgr-slot-thumb-wrap .slot-wm {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rpx 12rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.72));
  box-sizing: border-box;
}

.mgr-slot-thumb-wrap .slot-wm-line {
  font-size: 20rpx;
  color: #fff;
  line-height: 1.35;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.35);
}

.mgr-slot-code-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.mgr-slot-code {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.mgr-slot-body {
  padding: 16rpx 18rpx 18rpx;
}

.mgr-slot-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.mgr-tag-success { color: #15803d; background: #f0fdf4; }
.mgr-tag-danger { color: #b91c1c; background: #fef2f2; }
.mgr-tag-warning { color: #b45309; background: #fffbeb; }
.mgr-tag-expired { color: #991b1b; background: #fef2f2; }

.mgr-slot-line {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  font-size: 26rpx;
  color: #475569;
}

.mgr-slot-line:first-child { margin-top: 0; }
.mgr-slot-line--status { align-items: flex-start; }

.mgr-slot-k {
  flex-shrink: 0;
  width: 160rpx;
  color: #64748b;
  font-size: 26rpx;
}

.mgr-slot-v {
  flex: 1;
  text-align: right;
  font-weight: 600;
  color: #1e293b;
  font-size: 28rpx;
}

.mgr-slot-v--emph {
  color: #0f172a;
  font-size: 30rpx;
}

.mgr-slot-v.is-empty {
  font-weight: 400;
  color: #94a3b8;
  font-size: 24rpx;
}

.mgr-slot-status-cell {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx 12rpx;
}

.mgr-slot-status-tip {
  font-size: 22rpx;
  color: #64748b;
}

.mgr-slot-status-tip--danger { color: #b91c1c; }
.mgr-slot-status-tip--warn { color: #b45309; }
.mgr-slot-status-tip--expired { color: #991b1b; }

.mgr-slot-expire-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.mgr-slot-v--soon {
  color: #dc2626;
}

.mgr-slot-soon {
  font-size: 22rpx;
  font-weight: 600;
  color: #dc2626;
}

.mgr-more-link {
  margin-top: 8rpx;
  padding: 20rpx 4rpx;
  text-align: center;
  font-size: 26rpx;
  color: #1677ff;
  font-weight: 500;
}

.mgr-pick-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
}

.mgr-pick-sheet {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.mgr-pick-hd {
  text-align: center;
  padding: 22rpx 24rpx 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #64748b;
}

.mgr-pick-scroll {
  max-height: 48vh;
}

.mgr-pick-item {
  padding: 36rpx 28rpx;
  font-size: 44rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.mgr-pick-item.is-active {
  color: #1677ff;
  background: #eff6ff;
}

.mgr-pick-cancel {
  padding: 32rpx 24rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 600;
  color: #64748b;
  border-top: 12rpx solid #f1f5f9;
}
