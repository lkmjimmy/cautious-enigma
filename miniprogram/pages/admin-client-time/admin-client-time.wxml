<view class="page">
  <view class="intro">
    按广告位类型设置到期日，将同步到该客户名下对应类型的全部广告位；7 天内到期在列表中标红提醒。
  </view>
  <view class="client-hd">
    <text class="client-name">{{clientName}}</text>
  </view>

  <block wx:for="{{typeRows}}" wx:key="type">
    <view class="type-card">
      <view class="type-row">
        <text class="type-label">{{item.type}}</text>
        <text class="type-clear" data-index="{{index}}" bindtap="onClearType">清除</text>
      </view>
      <picker
        mode="date"
        value="{{item.dateValue || defaultDate}}"
        start="2020-01-01"
        end="2040-12-31"
        data-index="{{index}}"
        bindchange="onDateChange"
      >
        <view class="date-picker">
          <text class="date-value {{item.dateValue ? '' : 'is-placeholder'}}">
            {{item.dateValue || '点击选择到期日'}}
          </text>
          <text class="date-arrow">›</text>
        </view>
      </picker>
    </view>
  </block>

  <button class="btn-save" bindtap="saveAll">保存并同步</button>
</view>
