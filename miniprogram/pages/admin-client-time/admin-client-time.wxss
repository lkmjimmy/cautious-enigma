.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.client-hd {
  margin-bottom: 16rpx;
}

.client-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.type-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 14rpx;
}

.type-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.type-clear {
  font-size: 24rpx;
  color: #9ca3af;
  padding: 12rpx 8rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 0 18rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.date-value {
  font-size: 34rpx;
  font-weight: 600;
  color: #1677ff;
}

.date-value.is-placeholder {
  font-weight: 500;
  color: #9ca3af;
}

.date-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 300;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 24rpx;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: #1677ff;
  border-radius: 12rpx;
}

.btn-save::after {
  border: none;
}
