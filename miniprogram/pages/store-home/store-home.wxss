.page {
  padding-top: 16rpx;
}

.store-picker {
  display: flex;
  align-items: center;
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

.store-picker-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-right: 12rpx;
}

.store-picker-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.store-picker-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.store-bar {
  margin-bottom: 24rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
}

.store-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.45;
}

.month-checkin-card {
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: var(--radius-md);
}

.month-checkin-card--done {
  background: #ecfdf5;
  border-color: #6ee7b7;
}

.month-checkin-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.month-checkin-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.month-checkin-month {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.month-checkin-rules {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.55;
}

.month-checkin-strong {
  font-weight: 700;
  color: var(--text);
}

.month-checkin-status {
  margin-top: 14rpx;
}

.month-checkin-done {
  font-size: 26rpx;
  font-weight: 700;
  color: #047857;
}

.month-checkin-pending {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.month-checkin-pending-main {
  font-size: 26rpx;
  font-weight: 700;
  color: #b45309;
}

.month-checkin-pending-sub {
  font-size: 22rpx;
  color: #92400e;
  line-height: 1.45;
}

.month-checkin-muted {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.stat-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-item {
  flex: 1;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
  padding: 20rpx 12rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.stat-value.tone-success {
  color: #16a34a;
}

.stat-value.tone-danger {
  color: #dc2626;
}

.stat-value.tone-warning {
  color: #d97706;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.empty-hint {
  padding: 32rpx 20rpx;
  margin-bottom: 16rpx;
  text-align: center;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

.empty-hint-inner {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.group-card {
  margin-bottom: 16rpx;
  padding: 18rpx 16rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14rpx;
}

.thumb-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.thumb-cell {
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  background: var(--bg-elevated);
}

.thumb-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 62%;
  background: #f1f5f9;
}

.thumb-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.thumb-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 3;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(220, 38, 38, 0.92);
}

.thumb-watermark {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  padding: 10rpx 12rpx 8rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.58) 40%, rgba(0, 0, 0, 0.78) 100%);
  pointer-events: none;
}

.thumb-wm-line {
  font-size: 18rpx;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.96);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.45);
  word-break: break-all;
}

.thumb-wm-time {
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.thumb-wm-loc {
  margin-top: 4rpx;
  font-size: 17rpx;
  color: rgba(255, 255, 255, 0.9);
}

.thumb-code-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
  padding: 8rpx 12rpx 4rpx;
}

.thumb-code {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text);
  word-break: break-all;
}

.thumb-month-ok {
  flex-shrink: 0;
  font-size: 18rpx;
  font-weight: 600;
  color: #047857;
  background: #ecfdf5;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  align-self: center;
}

.thumb-meta {
  padding: 0 12rpx 6rpx;
}

.thumb-status {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.thumb-status.st-on {
  color: #15803d;
  background: #f0fdf4;
}

.thumb-status.st-soon {
  color: #b45309;
  background: #fffbeb;
}

.thumb-status.st-vacant {
  color: #b91c1c;
  background: #fef2f2;
}

.thumb-expire-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx 12rpx;
  border-top: 1rpx solid var(--border-light);
  gap: 8rpx;
}

.thumb-expire-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.thumb-expire-val {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text);
  text-align: right;
}

.thumb-expire-val.is-empty {
  font-weight: 500;
  color: var(--text-tertiary);
}

.thumb-expire-val.is-soon {
  color: #dc2626;
}

.link-block {
  margin-top: 8rpx;
  padding: 24rpx 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.link-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.link-arrow {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 300;
}

.link-block--sub .link-text {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-secondary);
}

.link-block--sub .link-arrow {
  color: var(--text-tertiary);
}

.revenue-entry {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.revenue-entry-main {
  flex: 1;
  min-width: 0;
}

.revenue-entry-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.revenue-entry-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.revenue-entry-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: 40rpx;
  color: var(--primary);
  font-weight: 300;
}
