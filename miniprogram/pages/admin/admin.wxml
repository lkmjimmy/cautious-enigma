<view class="page">
  <view class="section-title">核心看板</view>
  <view class="grid">
    <block wx:for="{{stats}}" wx:key="label">
      <view class="stat-card" data-filter="{{item.filter}}" bindtap="goFilteredSlots">
        <view class="stat-label">{{item.label}}</view>
        <view class="stat-value tone-{{item.tone}}">{{item.value}}</view>
      </view>
    </block>
  </view>

  <view class="section">
    <view class="section-title">按广告位类型统计</view>
    <view class="type-table">
      <view class="type-head">
        <view class="col-type">类型</view>
        <view class="col-num">投放</view>
        <view class="col-num">空置</view>
        <view class="col-num">即将到期</view>
      </view>
      <block wx:for="{{typeStats}}" wx:key="type">
        <view class="type-row">
          <view class="col-type">{{item.type}}</view>
          <view class="col-num num-success">{{item.filled}}</view>
          <view class="col-num num-danger">{{item.vacant}}</view>
          <view class="col-num num-warning">{{item.expiring}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">门店投放概览</view>
      <view class="link" bindtap="goSlots">查看全部广告位</view>
    </view>
    <block wx:for="{{stores}}" wx:key="name">
      <view class="row-card">
        <view class="row-title">{{item.name}}</view>
        <view class="store-table">
          <view class="store-head">
            <view class="col-type">类型</view>
            <view class="col-num">投放</view>
            <view class="col-num">空置</view>
            <view class="col-num">即将到期</view>
          </view>
          <block wx:for="{{item.types}}" wx:key="type">
            <view class="store-row">
              <view class="col-type">{{item.type}}</view>
              <view class="col-num num-success">{{item.filled}}</view>
              <view class="col-num num-danger">{{item.vacant}}</view>
              <view class="col-num num-warning">{{item.expiring}}</view>
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>

  <view class="section">
    <view class="section-title">高优先级处理</view>
    <block wx:for="{{urgentSlots}}" wx:key="code">
      <view class="row-card">
        <view class="row-top">
          <view class="row-title">{{item.code}}</view>
          <view class="tag {{item.status === '空置' ? 'tag-danger' : 'tag-warning'}}">{{item.status}}</view>
        </view>
        <view class="row-meta">{{item.store}} · 到期 {{item.expireAt}}</view>
      </view>
    </block>
  </view>
</view>
