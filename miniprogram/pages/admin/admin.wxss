.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.link {
  color: #1677ff;
  font-size: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card,
.row-card {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  padding: 20rpx;
}

.stat-card:active {
  opacity: 0.82;
}

.type-table {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  overflow: hidden;
}

.type-head,
.type-row {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
}

.type-head {
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 23rpx;
  color: #6b7280;
}

.type-row {
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 25rpx;
  color: #111827;
}

.type-row:last-child {
  border-bottom: 0;
}

.col-type {
  flex: 1.6;
}

.col-num {
  flex: 1;
  text-align: center;
}

.num-success { color: #389e0d; }
.num-danger { color: #cf1322; }
.num-warning { color: #d48806; }

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
}

.stat-value {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.tone-success { color: #52c41a; }
.tone-danger { color: #f5222d; }
.tone-warning { color: #faad14; }

.row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.row-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.store-table {
  margin-top: 14rpx;
  border: 1rpx solid #eef2f7;
  border-radius: 10rpx;
  overflow: hidden;
}

.store-head,
.store-row {
  display: flex;
  align-items: center;
  padding: 12rpx 14rpx;
}

.store-head {
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 22rpx;
  color: #6b7280;
}

.store-row {
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 24rpx;
  color: #111827;
}

.store-row:last-child {
  border-bottom: 0;
}

.tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-danger {
  color: #f5222d;
  background: #fff1f0;
}

.tag-warning {
  color: #d48806;
  background: #fff7e6;
}
