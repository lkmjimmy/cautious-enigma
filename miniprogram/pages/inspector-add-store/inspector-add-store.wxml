<view class="page">
  <view class="card">
    <view class="section-title">门店信息</view>
    <view class="field">
      <text class="label">店铺名称</text>
      <input class="input" value="{{storeName}}" bindinput="onStoreNameInput" placeholder="请输入店铺名称" />
    </view>

    <view class="field">
      <text class="label">地址</text>
      <input class="input" value="{{address}}" bindinput="onAddressInput" placeholder="请输入地址" />
    </view>

    <view class="field">
      <text class="label">联系电话</text>
      <input
        class="input"
        value="{{phone}}"
        bindinput="onPhoneInput"
        placeholder="请输入联系电话"
      />
    </view>

    <view class="actions">
      <button class="action-btn ghost" bindtap="onCancel">取消</button>
      <button class="action-btn primary" bindtap="onSave">保存并返回</button>
    </view>
  </view>
</view>

