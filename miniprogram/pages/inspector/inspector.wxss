.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.progress-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}

.title {
  font-size: 24rpx;
  color: #6b7280;
}

.value {
  margin-top: 8rpx;
  color: #1677ff;
  font-size: 38rpx;
  font-weight: 700;
}

.section-title {
  margin: 20rpx 0 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.add-store-hero {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}

.add-store-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.add-store-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
}

.add-store-btn {
  width: 100%;
  margin-top: 14rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: #1677ff;
}

.add-store-btn::after {
  border: none;
}

.add-store-btn-ghost {
  margin-top: 10rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.task-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
}

.task-main {
  margin-bottom: 12rpx;
}

.task-store {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.task-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.mini-btn {
  background: #eff6ff;
  color: #1677ff;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 0 18rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.mini-btn[disabled] {
  opacity: 0.55;
  background: #f3f4f6;
  color: #6b7280;
}

.form-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}

.empty {
  color: #9ca3af;
  font-size: 26rpx;
  padding: 48rpx 12rpx;
  text-align: center;
}

.line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.55;
  margin-bottom: 10rpx;
}

.line-muted {
  color: #6b7280;
}

.line-small {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 16rpx;
  margin-bottom: 10rpx;
}

.type-picker {
  font-size: 26rpx;
  color: #111827;
  padding: 10rpx 0;
}

.status-group {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.status {
  border: 1rpx solid #d1d5db;
  color: #6b7280;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
}

.status.active {
  border-color: #1677ff;
  color: #1677ff;
  background: #eff6ff;
}

.photo-box {
  border: 1rpx dashed #cbd5e1;
  border-radius: 12rpx;
  height: 280rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
}

.photo-placeholder {
  color: #9ca3af;
  font-size: 24rpx;
}

.photo {
  width: 100%;
  height: 100%;
}

.form-actions {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-row {
  display: flex;
  gap: 14rpx;
}

.action-row .action-btn {
  flex: 1;
}

.action-btn {
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-btn.ghost {
  background: #f3f4f6;
  color: #6b7280;
}

.action-btn.primary {
  background: #1677ff;
  color: #fff;
}

.action-btn::after {
  border: none;
}

.action-btn[disabled] {
  opacity: 0.55;
}

.saved-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.45;
}

