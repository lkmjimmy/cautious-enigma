.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 12rpx;
  text-align: center;
}

.value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1677ff;
}

.label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.section-title {
  margin: 24rpx 0 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.record-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 280rpx;
  background: #eef2f7;
}

.info {
  padding: 16rpx 18rpx 20rpx;
}

.slot {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.period {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.status {
  margin-top: 10rpx;
  font-size: 22rpx;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.ok {
  color: #389e0d;
  background: #f6ffed;
}

.warn {
  color: #d48806;
  background: #fff7e6;
}
