.page {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.page-fill {
  padding: 24rpx;
  padding-bottom: calc(24rpx + 300rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.price-notice-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 20rpx 20rpx 22rpx;
  margin-bottom: 20rpx;
}

.price-notice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.price-notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.price-notice-hint {
  font-size: 22rpx;
  color: #9ca3af;
}

.price-notice-body {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.55;
  word-break: break-all;
}

.price-notice-placeholder {
  min-height: 120rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.5;
  text-align: center;
  background: #f9fafb;
  border: 1rpx dashed #d1d5db;
  border-radius: 10rpx;
}

.exposure-notice-card {
  background: linear-gradient(180deg, #f0f7ff 0%, #fff 48%);
  border: 1rpx solid #dbeafe;
  border-radius: 14rpx;
  padding: 20rpx 20rpx 22rpx;
  margin-bottom: 20rpx;
}

.exposure-notice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.exposure-notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e40af;
}

.exposure-notice-hint {
  font-size: 22rpx;
  color: #64748b;
}

.exposure-notice-body {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.65;
  word-break: break-word;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 12rpx;
  text-align: center;
}

.value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1677ff;
}

.label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.section-title {
  margin: 24rpx 0 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.lb-table-wrap {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin-bottom: 8rpx;
}

.lb-table {
  min-width: 680rpx;
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  overflow: hidden;
}

.lb-head,
.lb-row {
  display: flex;
  align-items: stretch;
  font-size: 22rpx;
}

.lb-head {
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
  color: #6b7280;
  font-weight: 600;
}

.lb-row {
  border-bottom: 1rpx solid #f1f5f9;
  color: #111827;
}

.lb-row:last-child {
  border-bottom: 0;
}

.lb-col {
  padding: 14rpx 10rpx;
  box-sizing: border-box;
  line-height: 1.35;
  word-break: break-all;
}

.lb-col-code {
  flex: 1.35;
  min-width: 0;
}

.lb-col-type {
  flex: 0.55;
  min-width: 0;
}

.lb-col-store {
  flex: 1;
  min-width: 0;
}

.lb-col-qty {
  flex: 0.45;
  text-align: center;
}

.lb-col-date {
  flex: 1.05;
  min-width: 0;
}

.lb-col-date-cell {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.lb-date-soon {
  color: #cf1322;
  font-weight: 600;
}

.lb-soon {
  font-size: 20rpx;
  color: #cf1322;
  font-weight: 600;
}

.lb-legend {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.45;
}

.record-section-hint {
  margin: -4rpx 0 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.45;
}

.record-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
}

.record-meta {
  padding: 16rpx 18rpx 12rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.photo-stages {
  padding: 12rpx 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.photo-stage {
  width: 100%;
}

.photo-stage-title {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.photo-wrap {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #eef2f7;
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-watermark {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 14rpx 10rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.62) 38%, rgba(0, 0, 0, 0.78) 100%);
}

.wm-line {
  font-size: 20rpx;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.96);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.45);
}

.wm-time {
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.wm-loc {
  margin-top: 4rpx;
  font-size: 19rpx;
  color: rgba(255, 255, 255, 0.88);
  word-break: break-all;
}

.slot {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.period {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.status {
  margin-top: 10rpx;
  font-size: 22rpx;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.ok {
  color: #389e0d;
  background: #f6ffed;
}

.warn {
  color: #d48806;
  background: #fff7e6;
}

.adv-actions-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 10rpx 20rpx 12rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e9eef5;
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.adv-actions-caption {
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
}

.adv-actions-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
}

.adv-btn {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  padding: 0 4rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.adv-btn::after {
  border: none;
}

.adv-btn--outline {
  color: #1677ff;
  background: #fff;
  border: 1rpx solid #1677ff;
}

.adv-btn--expand {
  color: #d46b08;
  background: #fff7e6;
  border: 1rpx solid #ffc069;
}

.adv-btn--primary {
  color: #fff;
  background: #07c160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.22),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

