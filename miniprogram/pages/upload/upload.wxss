.container { padding: 40rpx; }
.order { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.limit { font-size: 26rpx; color: #1989fa; margin-bottom: 32rpx; }
.grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.item { width: 200rpx; height: 200rpx; position: relative; border-radius: 12rpx; overflow: hidden; }
.thumb { width: 100%; height: 100%; }
.del { position: absolute; top: 0; right: 0; width: 48rpx; height: 48rpx; background: rgba(0,0,0,.6); color: #fff; text-align: center; line-height: 48rpx; font-size: 36rpx; }
.add { border: 2rpx dashed #ccc; display: flex; align-items: center; justify-content: center; color: #999; font-size: 32rpx; }
.btn { margin-top: 60rpx; background: #1989fa; color: #fff; border-radius: 12rpx; }
