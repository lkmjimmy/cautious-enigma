.page {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.page-fill {
  padding: 24rpx;
  padding-bottom: calc(24rpx + 120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
}

.table {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  overflow: hidden;
}

.t-head,
.t-row {
  display: flex;
  align-items: stretch;
  font-size: 26rpx;
}

.t-head {
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f7;
  color: #6b7280;
  font-weight: 600;
  font-size: 24rpx;
}

.t-row {
  border-bottom: 1rpx solid #f1f5f9;
  color: #111827;
}

.t-row:last-child {
  border-bottom: 0;
}

.t-col {
  padding: 18rpx 14rpx;
  box-sizing: border-box;
  line-height: 1.35;
  word-break: break-all;
}

.t-col-store {
  flex: 1.2;
}

.t-col-type {
  flex: 1;
}

.t-col-qty {
  flex: 0.45;
  text-align: center;
  font-weight: 600;
  color: #1677ff;
}

.empty {
  padding: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #9ca3af;
}

.adv-bar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e9eef5;
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.adv-bar-btn {
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: #07c160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.22);
}

.adv-bar-btn::after {
  border: none;
}

.promote-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.promote-sheet {
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.promote-hd {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.promote-desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
  line-height: 1.45;
}

.promote-types-block {
  padding: 8rpx 0 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  margin-bottom: 4rpx;
}

.promote-types-hd {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 14rpx;
}

.promote-type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.promote-type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.promote-type-chip.is-on {
  color: #1677ff;
  background: #e8f3ff;
  border-color: #1677ff;
  font-weight: 600;
}

.promote-type-mark {
  font-size: 22rpx;
  width: 22rpx;
}

.promote-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.promote-label {
  font-size: 28rpx;
  color: #374151;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.promote-picker {
  flex: 1;
  text-align: right;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 12rpx 0;
  min-height: 44rpx;
}

.promote-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.promote-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.promote-btn::after {
  border: none;
}

.promote-btn.ghost {
  color: #6b7280;
  background: #f3f4f6;
}

.promote-btn.primary {
  color: #fff;
  background: #1677ff;
}

.expand-mask {
  align-items: flex-end;
  z-index: 210;
}

.expand-sheet {
  width: 100%;
  max-height: 92vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.expand-hd {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.expand-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.expand-scroll-x {
  width: 100%;
  max-height: 46vh;
  margin-bottom: 12rpx;
  white-space: nowrap;
}

.expand-table {
  display: inline-block;
  min-width: 720rpx;
  vertical-align: top;
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 12rpx;
  overflow: hidden;
}

.expand-head,
.expand-row {
  display: flex;
  align-items: stretch;
  font-size: 22rpx;
}

.expand-head {
  background: #f8fafc;
  color: #6b7280;
  font-weight: 600;
}

.expand-row {
  border-top: 1rpx solid #f1f5f9;
  color: #111827;
}

.ex-col {
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  line-height: 1.3;
  word-break: break-all;
  flex-shrink: 0;
}

.ex-store {
  width: 140rpx;
}

.ex-code {
  width: 168rpx;
}

.ex-type {
  width: 88rpx;
}

.ex-status {
  width: 96rpx;
}

.ex-exp {
  width: 108rpx;
}

.ex-pick {
  width: 88rpx;
  text-align: center;
}

.st-vacant {
  color: #1677ff;
  font-weight: 600;
}

.st-on {
  color: #389e0d;
}

.st-soon {
  color: #d48806;
}

.vacant-chip {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1677ff;
  background: #f0f7ff;
  border: 1rpx solid #91caff;
}

.vacant-chip--on {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
}

.vacant-na {
  color: #d1d5db;
  font-size: 22rpx;
}

.expand-selected-hint {
  font-size: 24rpx;
  color: #1677ff;
  margin-bottom: 8rpx;
}

.expand-period {
  border-top: 1rpx solid #f1f5f9;
  margin-top: 4rpx;
  padding-top: 8rpx;
}
