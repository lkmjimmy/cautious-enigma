<view class="page">
  <view class="card">
    <view class="section-title">门店信息</view>
    <view class="line"><text class="k">店铺名称：</text>{{storeName}}</view>
    <view class="line"><text class="k">地址：</text>{{address}}</view>
    <view class="line"><text class="k">联系电话：</text>{{phone}}</view>
  </view>

  <view class="card">
    <view class="section-title">广告位初始化</view>
    <view class="tip">请按类型逐一拍摄并保存。每保存一张即暂存一条广告位记录，全部类型完成后点击“确认生成广告位”。</view>

    <view class="step-header">
      <view class="step-title">当前类型：{{currentType}}</view>
      <view class="step-index">第 {{typeIndex + 1}} / {{types.length}} 类</view>
    </view>
    <view class="hint">请拍摄一个{{currentType}}广告位</view>

    <view class="preview-box" bindtap="choosePhoto">
      <block wx:if="{{currentDraftPhoto}}">
        <image class="preview-img" src="{{currentDraftPhoto}}" mode="aspectFill" />
        <view wx:if="{{draftWatermarkTime}}" class="draft-watermark">
          <view class="draft-wm-line">{{draftWatermarkTime}}</view>
          <view class="draft-wm-line">{{draftWatermarkAddress}}</view>
        </view>
      </block>
      <view wx:else class="placeholder">点击拍照</view>
    </view>

    <view class="row-meta">
      已暂存 {{currentTypeCount}} 张 · 累计 {{totalCount}} 张
      <text wx:if="{{noneByType[currentType]}}" class="none-flag"> · 当前类型已标记无</text>
    </view>

    <view class="photo-actions">
      <button class="action-btn none" bindtap="onSetNone">无</button>
      <button class="action-btn ghost" bindtap="onRetake">重拍</button>
      <button class="action-btn primary" bindtap="onSavePhoto">保存</button>
    </view>

    <view class="photo-actions">
      <button wx:if="{{!isLastType}}" class="action-btn next" bindtap="onNextType">确认下一步</button>
      <button wx:else class="action-btn confirm" bindtap="onConfirm">确认生成广告位</button>
    </view>

    <view class="actions">
      <button class="action-btn ghost" bindtap="onCancel">取消</button>
    </view>
  </view>
</view>

