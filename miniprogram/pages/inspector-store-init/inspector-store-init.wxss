.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.k {
  color: #6b7280;
  font-weight: 600;
}

.tip {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.step-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.step-title {
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.step-index {
  font-size: 24rpx;
  color: #6b7280;
}

.hint {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 14rpx;
}

.preview-box {
  position: relative;
  height: 300rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #f8fafc;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.draft-watermark {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 14rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.72));
  box-sizing: border-box;
}

.draft-wm-line {
  font-size: 20rpx;
  color: #fff;
  line-height: 1.35;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.35);
}

.placeholder {
  color: #9ca3af;
  font-size: 26rpx;
}

.row-meta {
  margin-top: 12rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.none-flag {
  color: #d48806;
}

.photo-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.actions {
  display: flex;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.ghost {
  background: #f3f4f6 !important;
  color: #6b7280 !important;
  font-weight: 700;
}

.action-btn.primary {
  background: #1677ff !important;
  color: #fff !important;
  font-weight: 700;
}

.action-btn.next {
  background: #2563eb !important;
  color: #fff !important;
  font-weight: 700;
}

.action-btn.confirm {
  background: #16a34a !important;
  color: #fff !important;
  font-weight: 700;
}

.action-btn.none {
  background: #fff7e6 !important;
  color: #ad6800 !important;
  border: 1rpx solid #ffd591;
  font-weight: 700;
}

