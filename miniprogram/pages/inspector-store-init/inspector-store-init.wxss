.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.k {
  color: #6b7280;
  font-weight: 600;
}

.tip {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 16rpx;
}

.plan-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.plan-row:first-child {
  border-top: none;
}

.type-label {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  flex-shrink: 0;
}

.plan-picker {
  text-align: right;
  font-size: 28rpx;
  color: #1677ff;
  font-weight: 600;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-btn {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.ghost {
  background: #f3f4f6 !important;
  color: #6b7280 !important;
  font-weight: 700;
}

.action-btn.primary {
  background: #1677ff !important;
  color: #fff !important;
  font-weight: 700;
}

