.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.contract-client {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.contract-img-wrap {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  overflow: hidden;
}

.contract-img {
  width: 100%;
  display: block;
}

.contract-wm {
  padding: 0 20rpx 12rpx;
}

.contract-wm-line {
  display: block;
  font-size: 22rpx;
  color: #475569;
  line-height: 1.45;
}

.contract-tip {
  padding: 16rpx 20rpx 20rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.45;
}

.contract-empty {
  margin-top: 80rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.contract-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
}

.contract-empty-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.55;
}
