.page {
  padding-top: 16rpx;
}

.owner-card {
  padding: 24rpx 22rpx 28rpx;
  margin-bottom: 24rpx;
}

.owner-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.owner-body {
  padding-top: 4rpx;
}

.owner-line {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.owner-label {
  width: 100rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.owner-value {
  color: var(--text);
  font-weight: 500;
}

.owner-empty {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.btn-remove-owner {
  margin-top: 20rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  padding: 0;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-item {
  flex: 1;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
  padding: 20rpx 12rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.stat-value.tone-success {
  color: #16a34a;
}

.stat-value.tone-danger {
  color: #dc2626;
}

.stat-value.tone-warning {
  color: #d97706;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.slot-row {
  margin-bottom: 16rpx;
  padding: 22rpx 20rpx;
}

.slot-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-code {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.slot-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.slot-expire {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--border-light);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-expire-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.slot-expire-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.slot-expire-value.is-empty {
  font-weight: 500;
  color: var(--text-tertiary);
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-success {
  color: #15803d;
  background: #f0fdf4;
}

.tag-danger {
  color: #b91c1c;
  background: #fef2f2;
}

.tag-warning {
  color: #b45309;
  background: #fffbeb;
}

.link-block {
  margin-top: 8rpx;
  padding: 24rpx 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.link-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.link-arrow {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 300;
}
