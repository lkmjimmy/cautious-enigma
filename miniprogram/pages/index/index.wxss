.index-wrap {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.index-hero {
  position: relative;
  padding: 48rpx 32rpx 56rpx;
  background: linear-gradient(145deg, #1677ff 0%, #3b8cff 48%, #69b1ff 100%);
  overflow: hidden;
}

.index-hero-inner {
  position: relative;
  z-index: 1;
}

.index-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-pill);
  letter-spacing: 1rpx;
}

.index-hero-title {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.25;
  letter-spacing: 0.5rpx;
}

.index-hero-desc {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.55;
  max-width: 92%;
}

.index-hero-deco {
  position: absolute;
  right: -40rpx;
  bottom: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  pointer-events: none;
}

.index-body {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.index-section-label {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 56rpx;
  margin-bottom: 28rpx;
  padding-left: 0;
  letter-spacing: 0.5rpx;
}

.role-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-md);
}

.role-card--hover {
  opacity: 0.92;
  transform: scale(0.992);
}

.role-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.role-icon--admin {
  background: linear-gradient(135deg, #e8f3ff, #dbeafe);
}

.role-icon--ad {
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
}

.role-icon--insp {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
}

.role-icon--store {
  background: linear-gradient(135deg, #eff6ff, #e0e7ff);
}

.role-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.role-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
}

.role-desc {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.45;
}

.role-chevron {
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: 48rpx;
  color: var(--text-tertiary);
  font-weight: 300;
  line-height: 1;
}

.index-logout {
  margin-top: 96rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-tertiary);
}
