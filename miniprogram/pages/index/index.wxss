/* 首页 — Apple 极简：浅灰底、大标题、列表式入口；底栏固定底部 */
.index-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
  box-sizing: border-box;
}

.index-main {
  flex: 1;
  min-height: 0;
}

.index-hero {
  padding: 32rpx 40rpx 40rpx;
  background: var(--bg-page);
}

.index-hero-inner {
  position: relative;
  z-index: 1;
}

.index-badge {
  display: inline-block;
  padding: 4rpx 0;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

.index-hero-title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.2;
  letter-spacing: -0.5rpx;
}

.index-hero-desc {
  margin-top: 12rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  max-width: 100%;
  font-weight: 400;
}

.index-body {
  margin-top: 0;
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.index-section-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  text-align: left;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  letter-spacing: 0.5rpx;
}

.role-card {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.role-card--hover {
  opacity: 0.88;
  background: #fafafa;
}

.role-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  background: #f2f2f7;
}

.role-icon--admin,
.role-icon--ad,
.role-icon--insp,
.role-icon--store {
  background: #f2f2f7;
}

.role-main {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.role-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.25;
  letter-spacing: -0.25rpx;
}

.role-desc {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  font-weight: 400;
}

.role-chevron {
  flex-shrink: 0;
  margin-left: 8rpx;
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
  line-height: 1;
}

.index-logout {
  flex-shrink: 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}
