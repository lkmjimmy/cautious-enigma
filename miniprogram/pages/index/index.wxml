<view class="index-wrap">
  <view class="index-hero">
    <view class="index-hero-inner">
      <view class="index-badge">广告位管理</view>
      <view class="index-hero-title">广告投放与现场协同</view>
      <view class="index-hero-desc">为管理者、门店、广告主与巡店员提供统一工作台，数据一目了然。</view>
    </view>
    <view class="index-hero-deco" aria-hidden="true" />
  </view>

  <view class="index-body">
    <view class="index-section-label">选择身份进入</view>

    <view class="role-card" hover-class="role-card--hover" bindtap="goAdmin">
      <view class="role-icon role-icon--admin">📊</view>
      <view class="role-main">
        <view class="role-title">管理者</view>
        <view class="role-desc">全门店投放、空置广告位与到期提醒</view>
      </view>
      <text class="role-chevron" aria-hidden="true">›</text>
    </view>

    <view class="role-card" hover-class="role-card--hover" bindtap="goStore">
      <view class="role-icon role-icon--store">🏪</view>
      <view class="role-main">
        <view class="role-title">门店</view>
        <view class="role-desc">认领门店后查看本店广告位与到期时间</view>
      </view>
      <text class="role-chevron" aria-hidden="true">›</text>
    </view>

    <view class="role-card" hover-class="role-card--hover" bindtap="goAdvertiser">
      <view class="role-icon role-icon--ad">📢</view>
      <view class="role-main">
        <view class="role-title">广告主</view>
        <view class="role-desc">查看投放记录与安装后的现场照片</view>
      </view>
      <text class="role-chevron" aria-hidden="true">›</text>
    </view>

    <view class="role-card" hover-class="role-card--hover" bindtap="goInspector">
      <view class="role-icon role-icon--insp">🚶</view>
      <view class="role-main">
        <view class="role-title">巡店员</view>
        <view class="role-desc">按门店任务巡查、拍照打卡与异常上报</view>
      </view>
      <text class="role-chevron" aria-hidden="true">›</text>
    </view>

    <view class="index-logout" bindtap="logout">退出登录</view>
  </view>
</view>
