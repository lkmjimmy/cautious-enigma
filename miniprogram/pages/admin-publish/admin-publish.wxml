<view class="page">
  <view class="section section--notice">
    <view class="section-title">发布新通知</view>
    <view class="price-notice-tip">点击按钮在弹窗中输入通知内容，保存后将展示在广告主「我的投放」页顶部（演示为本地存储）</view>
    <view wx:if="{{currentPublishedNotice}}" class="notice-preview">{{currentPublishedNotice}}</view>
    <button class="notice-open-btn" bindtap="openNoticeModal">发布新通知</button>
    <view wx:if="{{currentPublishedNotice}}" class="notice-clear-row">
      <text class="notice-clear-link" bindtap="clearPublishedNotice">清空已发布通知</text>
    </view>
  </view>

  <view wx:if="{{showNoticeModal}}" class="notice-mask" bindtap="closeNoticeModal">
    <view class="notice-sheet" catchtap="stopNoticeBubble">
      <view class="notice-sheet-hd">发布新通知</view>
      <textarea
        class="price-notice-textarea notice-sheet-textarea"
        value="{{noticeModalDraft}}"
        maxlength="500"
        placeholder="填写价格调整、档期说明等，广告主登录后即可看到"
        bindinput="onNoticeModalInput"
      />
      <view class="price-notice-actions">
        <button class="price-notice-btn price-notice-btn--ghost" size="mini" bindtap="closeNoticeModal">取消</button>
        <button class="price-notice-btn price-notice-btn--primary" size="mini" bindtap="publishNoticeFromModal">保存发布</button>
      </view>
    </view>
  </view>
</view>
