/**
 * 全局设计令牌 — Apple 极简 / iOS 风格
 * 主色：系统蓝 #007AFF；背景：iOS Grouped #F2F2F7
 */
page {
  --primary: #007aff;
  --primary-dark: #0051d5;
  --primary-soft: rgba(0, 122, 255, 0.1);
  --primary-muted: #f2f8ff;
  --bg-page: #f2f2f7;
  --bg-elevated: #ffffff;
  --bg-secondary: #ffffff;
  /* iOS 分隔线近似 */
  --border: rgba(60, 60, 67, 0.18);
  --border-light: rgba(60, 60, 67, 0.12);
  --text: #1d1d1f;
  --text-secondary: #86868b;
  --text-tertiary: #aeaeb2;
  --success: #34c759;
  --success-bg: rgba(52, 199, 89, 0.12);
  --danger: #ff3b30;
  --danger-bg: rgba(255, 59, 48, 0.08);
  --warning: #ff9500;
  --warning-bg: rgba(255, 149, 0, 0.12);
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-pill: 999rpx;
  --shadow-sm: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  --font-title: 600;
  background-color: var(--bg-page);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用页面容器 */
.ds-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
}

/* 分区标题：无装饰条，字重与留白为主 */
.ds-section-title {
  font-size: 28rpx;
  font-weight: var(--font-title);
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 0;
  border-left: none;
  line-height: 1.35;
  letter-spacing: 0.25rpx;
}

/* 卡片：白底、细线、轻阴影 */
.ds-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.ds-link {
  color: var(--primary);
  font-size: 28rpx;
}

button::after {
  border: none;
}
