/**
 * 全局设计令牌 — 广告位管理小程序
 * 主色与导航栏 #1677FF 对齐，便于各页复用 var(--*)
 */
page {
  --primary: #1677ff;
  --primary-dark: #0958d9;
  --primary-soft: #e8f3ff;
  --primary-muted: #eff6ff;
  /* 页面灰底偏 Apple 官网 / iOS 设置系 */
  --bg-page: #f5f5f7;
  --bg-elevated: #ffffff;
  --border: #e2e8f0;
  --border-light: #eef2f7;
  --text: #0f172a;
  --text-secondary: #64748b;
  --text-tertiary: #94a3b8;
  --success: #16a34a;
  --success-bg: #f0fdf4;
  --danger: #dc2626;
  --danger-bg: #fef2f2;
  --warning: #d97706;
  --warning-bg: #fffbeb;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-pill: 999rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  --shadow-md: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  --font-title: 600;
  background-color: var(--bg-page);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用页面容器：安全区与水平边距 */
.ds-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
}

/* 分区标题：左侧主色条 */
.ds-section-title {
  font-size: 30rpx;
  font-weight: var(--font-title);
  color: var(--text);
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary);
  line-height: 1.3;
}

/* 卡片表面 */
.ds-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

/* 文字链接 */
.ds-link {
  color: var(--primary);
  font-size: 24rpx;
}

button::after {
  border: none;
}
