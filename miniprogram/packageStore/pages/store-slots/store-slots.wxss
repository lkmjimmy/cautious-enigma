.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.group-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.thumb-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.thumb-item {
  position: relative;
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #eef2f7;
  background: #fff;
}

.thumb {
  width: 100%;
  height: 180rpx;
  display: block;
}

.slot-id {
  font-size: 22rpx;
  color: #4b5563;
  padding: 8rpx 10rpx;
  background: #fff;
}

.expire-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(220, 38, 38, 0.9);
}
