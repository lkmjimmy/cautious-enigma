.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 12000;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet-panel {
  width: 100%;
  max-height: 72vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.sheet-hd {
  text-align: center;
  padding: 26rpx 28rpx 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #64748b;
}

.sheet-scroll {
  max-height: 52vh;
}

.sheet-item {
  padding: 36rpx 28rpx;
  text-align: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.sheet-item.is-active {
  background: #eff6ff;
}

.sheet-item-text {
  font-size: 42rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.35;
}

.sheet-item.is-active .sheet-item-text {
  color: #1677ff;
}

.sheet-cancel {
  padding: 32rpx 28rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #64748b;
  border-top: 12rpx solid #f1f5f9;
}
