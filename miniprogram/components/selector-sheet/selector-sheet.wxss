.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 12000;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet-panel {
  width: 100%;
  max-height: 72vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.sheet-hd {
  text-align: center;
  padding: 26rpx 28rpx 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #86868b;
}

.sheet-scroll {
  max-height: 52vh;
}

.sheet-item {
  padding: 36rpx 28rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.sheet-item.is-active {
  background: rgba(0, 122, 255, 0.06);
}

.sheet-item-text {
  font-size: 38rpx;
  font-weight: 500;
  color: #1d1d1f;
  line-height: 1.35;
}

.sheet-item.is-active .sheet-item-text {
  color: #007aff;
}

.sheet-cancel {
  padding: 32rpx 28rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: #007aff;
  border-top: 12rpx solid #f2f2f7;
}
