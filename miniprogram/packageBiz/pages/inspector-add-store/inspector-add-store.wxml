<view class="page">
  <view class="card">
    <view class="section-title">门店信息</view>
    <view class="field">
      <text class="label">店铺名称</text>
      <input class="input" value="{{storeName}}" bindinput="onStoreNameInput" placeholder="请输入店铺名称" />
    </view>

    <view class="field">
      <text class="label">地址</text>
      <view class="addr-pick-row">
        <view class="map-pick" hover-class="map-pick--hover" bindtap="onChooseLocation">
          <text class="map-pick-icon" aria-hidden="true">📍</text>
          <text class="map-pick-text">地图选点</text>
        </view>
        <view class="map-pick map-pick--poi" hover-class="map-pick--hover" bindtap="onChoosePoi">
          <text class="map-pick-icon" aria-hidden="true">🔎</text>
          <text class="map-pick-text">搜索地点（POI）</text>
        </view>
      </view>
      <input class="input" value="{{address}}" bindinput="onAddressInput" placeholder="可手填或从地图/POI 生成" />
    </view>

    <view class="field">
      <text class="label">联系电话</text>
      <input
        class="input"
        type="digit"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
        placeholder="请输入11位手机号"
      />
    </view>

    <view class="actions">
      <button class="action-btn ghost" hover-class="btn-hover" bindtap="onCancel">取消</button>
      <button class="action-btn primary" hover-class="btn-hover" bindtap="onSave">保存并初始化广告位</button>
    </view>
  </view>
</view>

