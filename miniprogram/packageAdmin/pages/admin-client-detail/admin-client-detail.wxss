.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
}

.hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.badge.on {
  color: #389e0d;
  background: #f6ffed;
}

.badge.off {
  color: #64748b;
  background: #f1f5f9;
}

.line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.line .k {
  display: inline-block;
  min-width: 3.5em;
  color: #9ca3af;
  font-size: 24rpx;
}

.ad-block {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f1f5f9;
}

.ad-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #007AFF;
  margin-bottom: 8rpx;
}

.ad-line {
  display: block;
  font-size: 24rpx;
  color: #111827;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.none-ad {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.tip {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.contract-preview {
  width: 100%;
  display: block;
  border-radius: 12rpx;
  border: 1rpx solid #e9eef5;
  margin-bottom: 16rpx;
}

.contract-wm {
  margin-bottom: 16rpx;
  padding: 12rpx 14rpx;
  background: #f8fafc;
  border-radius: 10rpx;
  border: 1rpx solid #e9eef5;
}

.contract-wm-line {
  display: block;
  font-size: 22rpx;
  color: #475569;
  line-height: 1.45;
}

.contract-empty {
  padding: 32rpx;
  margin-bottom: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 1rpx dashed #d1d5db;
}

.btn-upload {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: #007AFF;
  border-radius: 12rpx;
}

.btn-upload::after {
  border: none;
}

.clear-row {
  margin-top: 12rpx;
  text-align: center;
}

.clear-link {
  font-size: 22rpx;
  color: #9ca3af;
  text-decoration: underline;
}

.btn-time {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 24rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #007AFF;
  background: #eff6ff;
  border-radius: 12rpx;
  border: 1rpx solid #bfdbfe;
}

.btn-time::after {
  border: none;
}

.schedule-block {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 24rpx;
}

.schedule-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 26rpx;
}

.schedule-row:last-child {
  border-bottom: none;
}

.schedule-type {
  color: #6b7280;
  min-width: 4em;
}

.schedule-date {
  font-weight: 600;
  color: #111827;
}

.schedule-date--soon {
  color: #dc2626;
}

.schedule-soon {
  font-size: 22rpx;
  font-weight: 600;
  color: #dc2626;
}

.schedule-empty {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.5;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 1rpx dashed #d1d5db;
}

.quote-tip {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.quote-block {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 8rpx 16rpx 16rpx;
  margin-bottom: 16rpx;
}

.quote-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.quote-row:last-child {
  border-bottom: none;
}

.quote-type {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.quote-fields {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx 12rpx;
}

.quote-k {
  font-size: 24rpx;
  color: #64748b;
}

.quote-picker {
  margin-right: 8rpx;
}

.quote-picker-inner {
  min-width: 120rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 600;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.quote-input {
  flex: 1;
  min-width: 200rpx;
  height: 72rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.btn-quote-save {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 0 28rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: #007AFF;
  border-radius: 12rpx;
}

.btn-quote-save::after {
  border: none;
}
