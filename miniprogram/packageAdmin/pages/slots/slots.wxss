.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.tab {
  font-size: 24rpx;
  color: #4b5563;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  white-space: nowrap;
}

.tab-active {
  color: #1677ff;
  border-color: #1677ff;
  background: #eff6ff;
}

.row-card {
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e9eef5;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.row-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.store-jump {
  margin-top: 12rpx;
  background: #eff6ff;
  border: 1rpx solid #dbeafe;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.store-name {
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 600;
}

.store-arrow {
  color: #1677ff;
  font-size: 24rpx;
}

.group-wrap {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.group-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  overflow: hidden;
}

.group-store {
  font-size: 27rpx;
  font-weight: 600;
  color: #111827;
  padding: 18rpx 18rpx 12rpx;
}

.group-table {
  border-top: 1rpx solid #eef2f7;
}

.group-head,
.group-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 18rpx;
}

.group-head {
  background: #f8fafc;
  color: #6b7280;
  font-size: 22rpx;
}

.group-row {
  border-top: 1rpx solid #f1f5f9;
  font-size: 23rpx;
  color: #374151;
}

.g-type {
  flex: 1.1;
}

.g-count {
  width: 70rpx;
  text-align: center;
}

.g-codes {
  flex: 2.2;
  padding-left: 12rpx;
  word-break: break-all;
}

.tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-success { color: #389e0d; background: #f6ffed; }
.tag-danger { color: #cf1322; background: #fff1f0; }
.tag-pending { color: #1d4ed8; background: #eff6ff; }
.tag-warning { color: #d48806; background: #fff7e6; }
