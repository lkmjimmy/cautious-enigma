.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.section--notice {
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.price-notice-tip {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
}

.notice-preview {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.5;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
  max-height: 120rpx;
  overflow: hidden;
}

.notice-open-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: #007AFF;
  border-radius: 12rpx;
}

.notice-open-btn::after {
  border: none;
}

.notice-clear-row {
  margin-top: 12rpx;
  text-align: center;
}

.notice-clear-link {
  font-size: 22rpx;
  color: #9ca3af;
  text-decoration: underline;
}

.notice-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.notice-sheet {
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.notice-sheet-hd {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.notice-sheet-textarea {
  min-height: 240rpx;
}

.price-notice-textarea {
  width: 100%;
  min-height: 168rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
  line-height: 1.5;
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 12rpx;
}

.price-notice-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.price-notice-btn {
  margin: 0;
  padding-left: 28rpx;
  padding-right: 28rpx;
  font-size: 24rpx;
  line-height: 2;
}

.price-notice-btn--primary {
  color: #fff;
  background: #007AFF;
}

.price-notice-btn--ghost {
  color: #6b7280;
  background: #f3f4f6;
}
