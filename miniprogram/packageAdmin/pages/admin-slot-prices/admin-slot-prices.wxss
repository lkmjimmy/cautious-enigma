.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.type-card {
  margin-bottom: 16rpx;
  padding: 22rpx 20rpx 20rpx;
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.cost-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 8rpx;
}

.dim-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 4rpx;
  line-height: 1.25;
}

.dim-input {
  width: 100%;
  height: 80rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.save-btn {
  margin-top: 8rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: #007AFF;
  border-radius: 12rpx;
}

.save-btn::after {
  border: none;
}
