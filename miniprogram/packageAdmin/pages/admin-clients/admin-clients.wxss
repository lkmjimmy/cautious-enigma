.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
}

.client-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 20rpx 22rpx 22rpx;
  margin-bottom: 14rpx;
}

.client-card:active {
  opacity: 0.82;
}

.client-hd {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.client-hd-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-del-client {
  margin: 0 !important;
  padding: 0 16rpx !important;
  height: 52rpx !important;
  line-height: 50rpx !important;
  font-size: 22rpx !important;
  background: #fef2f2 !important;
  color: #dc2626 !important;
  font-weight: 600;
  border: 1rpx solid #fecaca !important;
}

.btn-del-client::after {
  border: none;
}

.client-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.client-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.client-badge.on {
  color: #389e0d;
  background: #f6ffed;
}

.client-badge.off {
  color: #64748b;
  background: #f1f5f9;
}

.client-line {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.client-line .k {
  display: inline-block;
  min-width: 3.5em;
  color: #9ca3af;
  font-size: 24rpx;
}

.client-ad {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f1f5f9;
}

.client-ad-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 8rpx;
}

.client-ad-line {
  display: block;
  font-size: 24rpx;
  color: #111827;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.client-none {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
}
