.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 24rpx;
  box-sizing: border-box;
}

.summary {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.search {
  width: 100%;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 18rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search::placeholder {
  font-size: 26rpx;
  color: #9ca3af;
}

.slot-card {
  background: #fff;
  border: 1rpx solid #e9eef5;
  border-radius: 14rpx;
  padding: 16rpx;
  margin-bottom: 14rpx;
}

.thumb-wrap {
  position: relative;
  width: 100%;
  border-radius: 10rpx;
  overflow: hidden;
  background: #eef2f7;
}

.thumb-vacant {
  width: 100%;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #dc2626;
  background: #fef2f2;
}

.thumb-vacant--pending {
  color: #1d4ed8;
  background: #eff6ff;
}

.thumb {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  background: #eef2f7;
  display: block;
}

.thumb-wrap .slot-wm {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rpx 12rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.72));
  box-sizing: border-box;
}

.thumb-wrap .slot-wm-line {
  font-size: 20rpx;
  color: #fff;
  line-height: 1.35;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.35);
}

.meta {
  margin-top: 10rpx;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.code {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.line {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.expire-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.expire-soon {
  font-size: 22rpx;
  font-weight: 600;
  color: #dc2626;
}

.tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-ok {
  color: #065f46;
  background: #ecfdf5;
}

.tag-empty {
  color: #92400e;
  background: #fffbeb;
}

.bind-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bind-label {
  font-size: 24rpx;
  color: #6b7280;
}

.bind-picker {
  min-width: 180rpx;
  text-align: right;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 600;
  padding: 12rpx 0;
}

.slot-actions {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f1f5f9;
}

.btn-del-slot {
  margin: 0 !important;
  background: #fef2f2 !important;
  color: #dc2626 !important;
  font-weight: 600;
  border: 1rpx solid #fecaca !important;
}

.btn-del-slot::after {
  border: none;
}
